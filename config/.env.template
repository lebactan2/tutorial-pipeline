# Tutorial Pipeline Configuration
# Copy this file to .env and fill in your API keys

# Required: Anthropic API key for Claude script cleanup
# Get yours at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Optional: Antigravity (Gemini) API key as an alternative to Claude
# Get yours at https://aistudio.google.com/app/apikey
ANTIGRAVITY_API_KEY=
# Optional: Extra Gemini keys. The pipeline will try ANTIGRAVITY_API_KEY first,
# then these keys from left to right when quota/rate limit is hit.
ANTIGRAVITY_API_KEYS=

# Optional: MiniMax API key for cloud voice comparison
# Get yours at https://www.minimax.io → API Keys
# If left empty, only draft_local.mp4 will be produced
MINIMAX_API_KEY=

# Optional: OpenRouter API key for using multiple LLMs
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: Custom API URL and Key (e.g. for self-hosted or other OpenAI-compatible endpoints)
CUSTOM_API_BASE_URL=
CUSTOM_API_KEY=
